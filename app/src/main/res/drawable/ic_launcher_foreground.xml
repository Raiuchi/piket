<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">

    <!-- Хромированный медальон - r=33 строго по границе safe zone (66dp/108), тот же
         градиент металла, что борт спидометра в приложении -->
    <path android:strokeWidth="2.2" android:fillColor="#00000000"
        android:pathData="M54,21 a33,33 0 1,1 -0.1,0 z">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="21" android:startY="21" android:endX="87" android:endY="87">
                <item android:offset="0" android:color="#4A6182"/>
                <item android:offset="0.25" android:color="#DCE6F1"/>
                <item android:offset="0.5" android:color="#8FA6C0"/>
                <item android:offset="0.75" android:color="#4A6182"/>
                <item android:offset="1" android:color="#232F3E"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:strokeColor="#000000" android:strokeWidth="1" android:strokeAlpha="0.4"
        android:fillColor="#00000000" android:pathData="M54,22.8 a31.2,31.2 0 1,1 -0.1,0 z"/>

    <!-- Поезд Сапсан - масштаб 0.85, чтобы гарантированно уместиться внутри safe zone -->
    <group android:pivotX="0" android:pivotY="0" android:scaleX="0.85" android:scaleY="0.85"
        android:rotation="-4" android:translateX="54" android:translateY="54">

        <!-- Тень на "земле" (без блюра - VectorDrawable фильтры не поддерживает) -->
        <path android:fillColor="#000000" android:fillAlpha="0.35"
            android:pathData="M -36,15 a34,3.4 0 1,0 68,0 a34,3.4 0 1,0 -68,0 z"/>

        <!-- Пантограф на крыше -->
        <path android:strokeColor="#2B3646" android:strokeWidth="0.9" android:strokeLineCap="round"
            android:fillColor="#00000000" android:pathData="M -6,-4.6 L -6,-8.4 L -1,-11.4 L 3,-8.4 L 3,-4.9"/>
        <path android:strokeColor="#2B3646" android:strokeWidth="1.3" android:strokeLineCap="round"
            android:fillColor="#00000000" android:pathData="M -1,-11.4 L -1,-13.2"/>

        <!-- Корпус - клиновидный нос как у настоящего Velaro RUS -->
        <path android:strokeColor="#8FA0B4" android:strokeWidth="0.6"
            android:pathData="M -34,-4 L 10,-5 Q 22,-5.5 32,0 Q 22,5 10,6 L -34,7 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="0" android:startY="-5.5" android:endX="0" android:endY="7">
                    <item android:offset="0" android:color="#FFFFFF"/>
                    <item android:offset="0.35" android:color="#EAF1F8"/>
                    <item android:offset="0.6" android:color="#CBDAEA"/>
                    <item android:offset="1" android:color="#9FB2C7"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Холодный рефлекс по нижней кромке -->
        <path android:strokeColor="#BFD6EE" android:strokeWidth="0.6" android:strokeAlpha="0.5"
            android:strokeLineCap="round" android:fillColor="#00000000" android:pathData="M -34,6.3 L 9,5.3"/>

        <!-- Тонированное остекление -->
        <path android:pathData="M -29,-3.4 L 6,-4.2 Q 15,-4.4 21,-1.3 Q 15,1.6 6,1.9 L -29,2.5 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="-29" android:startY="-4.4" android:endX="21" android:endY="-2.33">
                    <item android:offset="0" android:color="#3A5170"/>
                    <item android:offset="0.55" android:color="#16283F"/>
                    <item android:offset="1" android:color="#0A1626"/>
                </gradient>
            </aapt:attr>
        </path>
        <path android:fillColor="#BFE0FF" android:fillAlpha="0.28"
            android:pathData="M -25,-2.8 L -4,-3.3 L -6,-1.2 L -25,-0.7 Z"/>

        <!-- Глянец по верхней кромке -->
        <path android:strokeColor="#FFFFFF" android:strokeWidth="0.7" android:strokeAlpha="0.45"
            android:strokeLineCap="round" android:fillColor="#00000000" android:pathData="M -30,-3.6 L 8,-4.6"/>

        <!-- Красная полоса ливреи, сужающаяся к носу -->
        <path android:pathData="M -34,6.3 L 12,5.3 L 12,4.85 L -34,5.75 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="-34" android:startY="5.3" android:endX="12" android:endY="5.3"
                    android:startColor="#E2231A" android:endColor="#FF6A5E"/>
            </aapt:attr>
        </path>
        <path android:strokeColor="#FFB3AC" android:strokeWidth="0.4" android:strokeAlpha="0.55"
            android:strokeLineCap="round" android:fillColor="#00000000" android:pathData="M -34,5.8 L 12,4.9"/>

        <!-- Тень юбки под кузовом вместо мультяшных колёс -->
        <path android:fillColor="#0A0E16" android:fillAlpha="0.75"
            android:pathData="M -34,6.9 L 20,5.55 L 20,6.35 L -34,7.6 Z"/>

        <!-- Фара -->
        <path android:fillColor="#FFEFC2"
            android:pathData="M 29.5,0 m -1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0"/>
    </group>
</vector>
